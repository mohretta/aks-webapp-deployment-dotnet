{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "sqlServerName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Azure SQL logical server."
      }
    },
    "sqlDatabaseName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Azure SQL database."
      }
    },
    "sqlAdminLogin": {
      "type": "string",
      "metadata": {
        "description": "SQL admin username."
      }
    },
    "sqlAdminPassword": {
      "type": "secureString",
      "metadata": {
        "description": "SQL admin password."
      }
    },
    "publicNetworkAccess": {
      "type": "string",
      "defaultValue": "Enabled",
      "allowedValues": ["Enabled", "Disabled"],
      "metadata": {
        "description": "Enable/disable public network access on the SQL server."
      }
    },
    "minimalTlsVersion": {
      "type": "string",
      "defaultValue": "1.2",
      "allowedValues": ["1.0", "1.1", "1.2"],
      "metadata": {
        "description": "Minimum TLS version."
      }
    },
    "databaseSkuName": {
      "type": "string",
      "defaultValue": "Basic",
      "allowedValues": ["Basic", "S0", "S1", "S2", "P1", "P2"],
      "metadata": {
        "description": "Database SKU name."
      }
    },
    "databaseSkuTier": {
      "type": "string",
      "defaultValue": "Basic",
      "allowedValues": ["Basic", "Standard", "Premium"],
      "metadata": {
        "description": "Database SKU tier."
      }
    },
    "collation": {
      "type": "string",
      "defaultValue": "SQL_Latin1_General_CP1_CI_AS",
      "metadata": {
        "description": "Database collation."
      }
    }
  },
  "variables": {},
  "resources": [
    {
      "type": "Microsoft.Sql/servers",
      "apiVersion": "2021-11-01",
      "name": "[parameters('sqlServerName')]",
      "location": "[parameters('location')]",
      "properties": {
        "administratorLogin": "[parameters('sqlAdminLogin')]",
        "administratorLoginPassword": "[parameters('sqlAdminPassword')]",
        "publicNetworkAccess": "[parameters('publicNetworkAccess')]",
        "minimalTlsVersion": "[parameters('minimalTlsVersion')]"
      },
      "resources": [
        {
          "type": "databases",
          "apiVersion": "2021-11-01",
          "name": "[parameters('sqlDatabaseName')]",
          "location": "[parameters('location')]",
          "dependsOn": [
            "[resourceId('Microsoft.Sql/servers', parameters('sqlServerName'))]"
          ],
          "sku": {
            "name": "[parameters('databaseSkuName')]",
            "tier": "[parameters('databaseSkuTier')]"
          },
          "properties": {
            "collation": "[parameters('collation')]"
          }
        }
      ]
    }
  ],
  "outputs": {
    "sqlServerResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Sql/servers', parameters('sqlServerName'))]"
    },
    "sqlDatabaseResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Sql/servers/databases', parameters('sqlServerName'), parameters('sqlDatabaseName'))]"
    }
  }
}